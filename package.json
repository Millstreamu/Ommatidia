{
  "name": "engineering-design-assistant-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo scaffold for an engineering design assistant",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install && node scripts/dev-setup.mjs",
    "dev": "bash scripts/dev-start.sh",
    "start": "npm run dev",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "check": "npm run typecheck && npm run test",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "node scripts/dev-clean.mjs",
    "reset-local": "node scripts/dev-reset-local.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
