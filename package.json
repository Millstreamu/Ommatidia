{
  "name": "engineering-design-assistant-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo scaffold for an engineering design assistant",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
