#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REVIEW_MD="${BEEBOT_REVIEW_MD_PATH:-$SCRIPT_DIR/latest-session-review.md}"
REVIEW_RAW="${BEEBOT_REVIEW_RAW_PATH:-$SCRIPT_DIR/latest-session-raw.txt}"
BATCH_ROOT="${BEEBOT_BATCH_ROOT:-$SCRIPT_DIR/batch-runs}"

echo "[status_all] collecting status"
echo "branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
echo "commit: $(git rev-parse --short HEAD 2>/dev/null || echo unknown)"
echo "review_md: $REVIEW_MD"
echo "review_raw: $REVIEW_RAW"
[[ -f "$REVIEW_MD" ]] && echo "review_md_present: yes" || echo "review_md_present: no"
[[ -f "$REVIEW_RAW" ]] && echo "review_raw_present: yes" || echo "review_raw_present: no"
if [[ -d "$BATCH_ROOT" ]]; then
  newest="$(ls -1 "$BATCH_ROOT" 2>/dev/null | tail -n 1 || true)"
  [[ -n "$newest" ]] && echo "latest_batch_run: $BATCH_ROOT/$newest" || echo "latest_batch_run: none"
else
  echo "latest_batch_run: none"
fi
echo "safe hooks:"
echo "  BEEBOT_SESSION_START_CMD=${BEEBOT_SESSION_START_CMD:-<default:true>}"
echo "  BEEBOT_SESSION_STOP_CMD=${BEEBOT_SESSION_STOP_CMD:-<default:true>}"
echo "  BEEBOT_REVIEW_CMD=${BEEBOT_REVIEW_CMD:-$SCRIPT_DIR/run-review}"
