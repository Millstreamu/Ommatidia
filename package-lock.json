{
  "name": "engineering-design-assistant-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "engineering-design-assistant-monorepo",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@ommatidia/api",
      "version": "0.1.0",
      "dependencies": {
        "@ommatidia/calculations": "0.1.0",
        "@ommatidia/extraction": "0.1.0",
        "@ommatidia/reports": "0.1.0",
        "@ommatidia/shared": "0.1.0"
      }
    },
    "apps/web": {
      "name": "@ommatidia/web",
      "version": "0.1.0",
      "dependencies": {
        "@ommatidia/shared": "0.1.0"
      }
    },
    "node_modules/@ommatidia/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@ommatidia/calculations": {
      "resolved": "packages/calculations",
      "link": true
    },
    "node_modules/@ommatidia/extraction": {
      "resolved": "packages/extraction",
      "link": true
    },
    "node_modules/@ommatidia/reports": {
      "resolved": "packages/reports",
      "link": true
    },
    "node_modules/@ommatidia/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@ommatidia/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/calculations": {
      "name": "@ommatidia/calculations",
      "version": "0.1.0",
      "dependencies": {
        "@ommatidia/shared": "0.1.0"
      }
    },
    "packages/extraction": {
      "name": "@ommatidia/extraction",
      "version": "0.1.0",
      "dependencies": {
        "@ommatidia/shared": "0.1.0"
      }
    },
    "packages/reports": {
      "name": "@ommatidia/reports",
      "version": "0.1.0",
      "dependencies": {
        "@ommatidia/shared": "0.1.0"
      }
    },
    "packages/shared": {
      "name": "@ommatidia/shared",
      "version": "0.1.0"
    }
  }
}
